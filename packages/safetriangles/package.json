{
  "name": "@finsweet/attributes-safetriangles",
  "version": "0.0.0",
  "description": "Generate safe triangles between trigger and target elements to keep context menus open while users move the pointer.",
  "private": true,
  "type": "module",
  "types": "src/index.ts",
  "scripts": {
